# Localweb — n8n Docker Environment
# Kopiere diese Datei nach .env und fuelle echte Werte ein:
#   cp .env.example .env

# ── n8n Encryption ────────────────────────────────────────────────────────────
# Langen Zufallsstring generieren: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change_me_to_a_long_random_string
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=n8n_localweb
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me

# ── Task Runner (PFLICHT fuer n8n >= 2.0) ───────────────────────────────────
# IMMER External Mode verwenden! Internal Mode hat 403-Auth-Race → 100-300% CPU.
# Siehe: skills/n8n/SKILL.md und knowledge/learnings/task-runner.md
N8N_RUNNERS_MODE=external
N8N_RUNNERS_AUTH_TOKEN=change_me_openssl_rand_base64_32

# ── Produktion ──────────────────────────────────────────────────────────────
N8N_HOST=n8n.hoba-consulting.com
N8N_LOG_FORMAT=json
N8N_LOG_LEVEL=warn
N8N_METRICS=true

# ── Localweb Credentials ─────────────────────────────────────────────────────

# Supabase google-maps-lead-pipeline
SUPABASE_GOOGLE_URL=https://your-project.supabase.co
SUPABASE_GOOGLE_KEY=your_supabase_service_role_key_here

# Supabase close-sync
SUPABASE_LEADS_URL=https://your-project.supabase.co
SUPABASE_LEADS_KEY=your_supabase_service_role_key_here

# Apify
APIFY_API_TOKEN=your_apify_token_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Close CRM
CLOSE_API_KEY=your_close_api_key_here

# DocuSeal
DOCUSEAL_API_KEY=your_docuseal_api_key_here

# Email / SMTP
NOTIFICATION_EMAIL=alerts@example.com

# Demodesk
DEMODESK_API_KEY=your_demodesk_api_key_here
DEMODESK_API_KEY_BRANTAN=
DEMODESK_API_KEY_AMADEUS=
DEMODESK_API_KEY_LILIAN=
DEMODESK_API_KEY_THOMAS=
DEMODESK_API_KEY_PETER=

# Google Drive
GOOGLE_DRIVE_DEMODESK_FOLDER_ID=
