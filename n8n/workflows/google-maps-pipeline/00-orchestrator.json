      "parameters": {
        "jsCode": "// Robust check: handle empty array, error responses, and track poll count\nconst response = $input.first().json;\n\n// Check if response is an actual Supabase result (array items get unpacked)\n// Empty result from Supabase returns [] which n8n unpacks to item with empty json {}\nconst hasId = response.id !== undefined && response.id !== null;\nconst hasPending = hasId;\n\nconst dispatchedAt = $('Record Dispatch Time').first().json.dispatchedAt;\nconst maxWaitMinutes = $('Record Dispatch Time').first().json.maxWaitMinutes;\nconst elapsedMs = Date.now() - new Date(dispatchedAt).getTime();\nconst elapsedMinutes = Math.round(elapsedMs / 60000);\nconst isTimedOut = elapsedMinutes >= maxWaitMinutes;\n\n// Track poll count for debugging\nlet pollCount = 0;\ntry {\n  pollCount = $('Evaluate Poll').first().json.pollCount || 0;\n} catch(e) { /* first iteration */ }\npollCount++;\n\nreturn [{ json: { hasPending, isTimedOut, elapsedMinutes, pollCount } }];"
      },
