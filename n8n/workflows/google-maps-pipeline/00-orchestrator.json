        "jsCode": "// Collect search strings from location data (test path or manual path)\nlet queries = [];\ntry {\n  const items = $('Setup Test Location').all();\n  queries = items.map(item => item.json.query).filter(Boolean);\n} catch(e) {}\n\nif (queries.length === 0) {\n  try {\n    const items = $('Get All Locations').all();\n    queries = items.map(item => item.json.query).filter(Boolean);\n  } catch(e) {}\n}\n\nconst unique = [...new Set(queries)];\nconst searchFilter = unique.length > 0 ? `in.(${unique.join(',')})` : '';\nreturn [{ json: { searchFilter, searchStrings: unique } }];"
