      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [1344, 288],
      "parameters": {
        "conditions": {
          "options": { "version": 3, "leftValue": "", "caseSensitive": true, "typeValidation": "strict" },
          "conditions": [
            {
              "id": "1",
              "leftValue": "={{ $json.source }}",
              "rightValue": "cache",
