    {
      "id": "openai-check",
      "name": "OpenAI Category Check",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1792, 488],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.OPENAI_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Du pr\\u00fcfst ob eine Google Maps Kategorie zum Suchbegriff passt. Ein Suchbegriff beschreibt eine Branche oder Dienstleistung. Die Kategorie ist die Google Maps Hauptkategorie des Unternehmens.\\n\\nAntworte NUR mit validem JSON: {\\\"relevant\\\": true/false, \\\"reason\\\": \\\"Kurze Begr\\u00fcndung\\\"}\\n\\nBeispiele:\\n- Suchbegriff: Umzugsunternehmen, Kategorie: Umzugsunternehmen \\u2192 relevant: true\\n- Suchbegriff: Umzugsunternehmen, Kategorie: Steuerberater \\u2192 relevant: false\\n- Suchbegriff: Umzugsunternehmen, Kategorie: Spedition \\u2192 relevant: true (verwandte Branche)\\n\\nSei gro\\u00dfz\\u00fcgig bei verwandten Branchen, aber strikt bei komplett unverwandten.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify(\"Suchbegriff: \" + $json.keyword + \"\\nKategorie: \" + $json.category) }}\n    }\n  ]\n}",
        "options": {
          "timeout": 30000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "id": "parse-result",
      "name": "Parse Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2016, 488],
      "parameters": {
        "jsCode": "try {\n  const content = $input.first().json.choices[0].message.content;\n  const parsed = JSON.parse(content);\n  return [{ json: {\n    relevant: !!parsed.relevant,\n    reason: parsed.reason || '',\n    keyword: $('Loop Over Uncached').first().json.keyword,\n    category: $('Loop Over Uncached').first().json.category\n  }}];\n} catch (e) {\n  return [{ json: {\n    relevant: false,\n    reason: 'Parse error - defaulting to not relevant',\n    keyword: $('Loop Over Uncached').first().json.keyword,\n    category: $('Loop Over Uncached').first().json.category\n  }}];\n}"
      }
    },
