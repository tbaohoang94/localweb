    {
      "id": "extract-pairs",
      "name": "Extract Unique Pairs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [672, 288],
      "parameters": {
        "jsCode": "const items = $input.all().map(i => i.json);\nconst pairs = {};\nfor (const item of items) {\n  const parts = item.search_string.split(' ');\n  const keyword = parts.length > 2 ? parts.slice(0, -2).join(' ') : parts[0];\n  const key = `${keyword}|||${item.category}`;\n  if (!pairs[key]) {\n    pairs[key] = { keyword, category: item.category, count: 0 };\n  }\n  pairs[key].count++;\n}\nreturn Object.values(pairs).map(p => ({ json: p }));"
      }
    },
    {
      "id": "fetch-cache",
      "name": "Fetch Cache",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [896, 288],
      "parameters": {
        "url": "={{ $env.SUPABASE_GOOGLE_URL }}/rest/v1/category_qualifications?select=keyword,category,relevant,reason&limit=5000",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_GOOGLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_GOOGLE_KEY }}" }
          ]
        },
        "options": {}
      },
      "alwaysOutputData": true
    },
    {
      "id": "split-cached",
      "name": "Split Cached vs Uncached",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 288],
      "parameters": {
        "jsCode": "const pairs = $('Extract Unique Pairs').all().map(i => i.json);\nconst cacheItems = $('Fetch Cache').all().map(i => i.json);\n\n// Cache-Map aufbauen\nconst cacheMap = new Map();\nfor (const c of cacheItems) {\n  if (c.keyword && c.category) {\n    cacheMap.set(`${c.keyword}|||${c.category}`, c);\n  }\n}\n\nconst cached = [];\nconst uncached = [];\n\nfor (const pair of pairs) {\n  const key = `${pair.keyword}|||${pair.category}`;\n  const hit = cacheMap.get(key);\n  if (hit) {\n    cached.push({ json: { ...pair, relevant: hit.relevant, reason: hit.reason, source: 'cache' } });\n  } else {\n    uncached.push({ json: { ...pair, source: 'openai' } });\n  }\n}\n\n// Statistik ausgeben\nconst stats = { total: pairs.length, cached: cached.length, uncached: uncached.length };\n\n// Beide Listen zusammen zurueckgeben, mit source-Flag zur Unterscheidung\nreturn [...cached, ...uncached];"
      }
    },
