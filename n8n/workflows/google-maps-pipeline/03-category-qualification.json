    {
      "id": "check-has-data",
      "name": "Has New Businesses?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [448, 288],
      "parameters": {
        "conditions": {
          "options": { "version": 3, "leftValue": "", "caseSensitive": true, "typeValidation": "loose" },
          "conditions": [
            {
