        "httpBasicAuth": {
          "id": "c1zqLlNCaOTBnrvH",
          "name": "Close.io"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const leadResponse = $items(\"Get Lead Fields\");\nconst oppResponse = $items(\"Get Opportunity Fields\");\nconst actResponse = $items(\"Get Activity Fields\");\nlet results = [];\n\nfor (const page of leadResponse) {\n  const fields = page.json.data || [];\n  for (const f of fields) {\n    results.push({\n      json: {\n        close_field_id: f.id,\n        name: f.name,\n        entity_type: 'lead',\n        field_type: f.type || null,\n        synced_at: new Date().toISOString()\n      }\n    });\n  }\n}\n\nfor (const page of oppResponse) {\n  const fields = page.json.data || [];\n  for (const f of fields) {\n    results.push({\n      json: {\n        close_field_id: f.id,\n        name: f.name,\n        entity_type: 'opportunity',\n        field_type: f.type || null,\n        synced_at: new Date().toISOString()\n      }\n    });\n  }\n}\n\nfor (const page of actResponse) {\n  const fields = page.json.data || [];\n  for (const f of fields) {\n    results.push({\n      json: {\n        close_field_id: f.id,\n        name: f.name,\n        entity_type: 'activity',\n        field_type: f.type || null,\n        synced_at: new Date().toISOString()\n      }\n    });\n  }\n}\n\nreturn results;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        300
      ],
      "id": "d1a1b1c1-0005-4000-a000-000000000005",
      "name": "Transform for Supabase"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_LEADS_URL }}/rest/v1/custom_fields?on_conflict=close_field_id",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
