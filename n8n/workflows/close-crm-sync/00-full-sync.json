      "alwaysOutputData": true,
      "parameters": {
        "url": "={{ $env.SUPABASE_LEADS_URL }}/rest/v1/sync_runs?select=entity,finished_at&status=eq.success&order=finished_at.desc&limit=50",
        "sendHeaders": true,
