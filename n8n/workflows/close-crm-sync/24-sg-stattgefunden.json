      "name": "Whisper Transcribe"
    },
    {
      "parameters": {
        "jsCode": "// Whisper-Ergebnis formatieren\nconst whisperResult = $json;\nconst callData = $('Prepare Download').first().json;\n\nfunction uuid() {\n  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {\n    const r = Math.random() * 16 | 0;\n    return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);\n  });\n}\n\nconst transcriptText = typeof whisperResult === 'string'\n  ? whisperResult\n  : (whisperResult.text || JSON.stringify(whisperResult));\n\nconst transcript = {\n  source_type: 'call',\n  source_id: uuid(),\n  content: transcriptText,\n  call_type: 'strategiegespraech',\n  url: callData.recordingUrl,\n  synced_at: new Date().toISOString()\n};\n\nreturn [{ json: {\n  transcripts: [transcript],\n  count: 1,\n  errors: []\n}}];\n",
        "mode": "runOnceForAllItems"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2160,
        100
      ],
      "id": "fmt-tr-sg-01",
      "name": "Format Transcript"
    },
