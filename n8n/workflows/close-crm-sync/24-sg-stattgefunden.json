        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ entity: 'webhook_24_sg_stattgefunden', status: 'error', error_message: ($json.error?.message || $json.errorMessage || 'Failed to update opportunity').substring(0, 500), started_at: new Date().toISOString(), finished_at: new Date().toISOString() }) }}",
