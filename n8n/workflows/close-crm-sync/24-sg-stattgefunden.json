      "continueOnFail": true,
      "id": "801efb4f-a91e-4ec7-ae27-bb235c70c5e0"
    },
    {
      "parameters": {
        "jsCode": "// Trigger-Daten holen und Datumsfenster berechnen\nconst trigger = $json;\nconst dateCreated = trigger.dateCreated || new Date().toISOString();\nconst date = new Date(dateCreated);\nconst dayStart = new Date(date.getFullYear(), date.getMonth(), date.getDate()).toISOString();\nconst dayEnd = new Date(date.getFullYear(), date.getMonth(), date.getDate() + 1).toISOString();\n\nreturn [{ json: { ...trigger, dayStart, dayEnd, attempt: 0 } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        200
      ],
      "id": "prep-sg-01",
      "name": "Prepare"
    },
    {
      "parameters": {
        "url": "=https://api.close.com/api/v1/activity/call/?lead_id={{ $json.leadId }}&date_created__gte={{ $json.dayStart }}&date_created__lt={{ $json.dayEnd }}&_limit=100",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Basic YXBpXzJKd0JqaHMwYmZCUmJ5d3dHeXA0blUuMWlWV0NZVUUyRzE3NWh6NjJmNEJMRzo="
            },
            {
              "name": "Accept",
              "value": "application/json"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        720,
        200
      ],
      "id": "get-calls-sg-01",
      "name": "GET Calls"
    },
    {
      "parameters": {
        "jsCode": "// Calls mit Recording filtern, Versuch zaehlen, Abbruch bei >= 2\nconst callsData = $json.data || [];\n\nlet prevAttempt = 0;\ntry { prevAttempt = $('Next Attempt').first().json.attempt; } catch(e) {\n  try { prevAttempt = $('Prepare').first().json.attempt; } catch(e2) {}\n}\nconst attempt = prevAttempt + 1;\n\n// Nur nach recording_url filtern\nconst callsWithRecording = callsData.filter(c => c.recording_url);\n\nif (callsWithRecording.length > 0) {\n  return [{ json: { _action: 'transcribe', calls: callsWithRecording, attempt } }];\n}\n\nif (attempt >= 2) {\n  return []; // Max Versuche erreicht\n}\n\nreturn [{ json: { _action: 'retry', calls: [], attempt } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        200
      ],
      "id": "check-calls-sg-01",
      "name": "Check Calls"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "action-check",
              "leftValue": "={{ $json._action }}",
              "rightValue": "transcribe",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1200,
        200
      ],
      "id": "has-rec-sg-01",
      "name": "Has Recording?"
    },
    {
      "parameters": {
        "resume": "timeInterval",
        "amount": 2,
        "unit": "minutes"
      },
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        1440,
        400
      ],
      "id": "wait-sg-01",
      "name": "Wait 2min Retry"
    },
    {
      "parameters": {
        "jsCode": "// Attempt-Zaehler beibehalten fuer naechsten Loop\nconst prev = $('Check Calls').first().json;\nconst trigger = $('Execute Workflow Trigger').first().json;\nconst prepare = $('Prepare').first().json;\n\nreturn [{ json: { ...trigger, dayStart: prepare.dayStart, dayEnd: prepare.dayEnd, attempt: prev.attempt } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1680,
        400
      ],
      "id": "next-att-sg-01",
      "name": "Next Attempt"
    },
    {
      "parameters": {
        "jsCode": "// Calls mit Recording vorbereiten fuer HTTP Download\nconst calls = $('Check Calls').first().json.calls || [];\n\nif (calls.length === 0) {\n  return [{ json: { transcripts: [], count: 0, errors: [] } }];\n}\n\nconst call = calls[0];\nreturn [{ json: {\n  callId: call.id,\n  recordingUrl: call.recording_url,\n  callsCount: calls.length\n}}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        100
      ],
      "id": "prep-dl-sg-01",
      "name": "Prepare Download"
    },
