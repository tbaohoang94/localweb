      "name": "GET Active Opportunity",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        480,
        600
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "id": "e349ee60-0a58-4744-af74-b380218717b5"
    },
    {
      "parameters": {
        "jsCode": "const input = $('Execute Workflow Trigger').first().json;\nconst oppResponse = $('GET Active Opportunity').first().json;\nconst opportunities = oppResponse.data || [];\n\nif (opportunities.length === 0) {\n  return [];\n}\n\nconst opp = opportunities[0];\nconst ergebnis = (input.customFields || {})['custom.cf_HCpCPtrExVmNACqjhFkjZ9fMHQimVgodE22DYt50ycf'] || '';\n\nconst STATUS_MAP = {\n  '1 - Kunde': 'stat_FCEzWzOeUGxQDxBECumKi1o5M0F1xIlOaFn13wvuJeh',\n  '2 - Folgetermin': 'stat_FCEzWzOeUGxQDxBECumKi1o5M0F1xIlOaFn13wvuJeh',\n  '3 - Follow-up': 'stat_tvzdFtr0O0RFU0Kq0XGWcWmX3ARkkbdYtwIAa8nw3QO',\n  '4 - Verloren': 'stat_2NjdTtgLsl931S2nrmOLTK7IWW7KV0JVsiTwS7zexT4',\n  '5 - Unqualifiziert': 'stat_0o8JNmzSa6GiQH5yEZ424xT9B08NGTia4U3VxxzssMB'\n};\n\nconst statusId = STATUS_MAP[ergebnis];\n\nif (!statusId) {\n  return [];\n}\n\nreturn [{ json: { oppId: opp.id, statusId, ergebnis, leadId: input.leadId } }];"
      },
      "name": "Resolve Ergebnis",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        600
      ],
      "id": "c8252ded-9291-406a-be1a-213d0fcb666d"
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "=https://api.close.com/api/v1/opportunity/{{ $json.oppId }}",
        "authentication": "none",
