      "parameters": {
        "jsCode": "// Parse chat input for test\nconst chatInput = $input.first()?.json?.chatInput || '';\nlet params = { date_created__gte: '', date_created__lte: '', lead_id: '' };\n\ntry {\n  const parsed = JSON.parse(chatInput);\n  params = { ...params, ...parsed };\n} catch (e) {\n  // Use defaults for today\n  const today = new Date();\n  const tomorrow = new Date(today);\n  tomorrow.setDate(tomorrow.getDate() + 1);\n  params.date_created__gte = today.toISOString().split('T')[0];\n  params.date_created__lte = tomorrow.toISOString().split('T')[0];\n}\n\nreturn [{ json: params }];"
      },
