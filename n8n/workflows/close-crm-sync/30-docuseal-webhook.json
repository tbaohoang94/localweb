    {
      "parameters": {
        "jsCode": "// Aus der Lead-Suche alle Lead-IDs extrahieren und Opps holen\nconst searchResult = $json;\nconst leads = searchResult.data || [];\n\nif (leads.length === 0) {\n  return [];\n}\n\nconst leadIds = leads.map(l => l.id);\nconst allOpps = [];\n\nfor (const leadId of leadIds) {\n  try {\n    const oppResp = await this.helpers.httpRequest({\n      method: 'GET',\n      url: 'https://api.close.com/api/v1/opportunity/?lead_id=' + leadId + '&status_type=active&_limit=100',\n      headers: {\n        'Authorization': 'Basic YXBpXzJKd0JqaHMwYmZCUmJ5d3dHeXA0blUuMWlWV0NZVUUyRzE3NWh6NjJmNEJMRzo=',\n        'Accept': 'application/json'\n      },\n      timeout: 30000\n    });\n\n    const opps = (typeof oppResp === 'string' ? JSON.parse(oppResp) : oppResp).data || [];\n    for (const opp of opps) {\n      allOpps.push({ oppId: opp.id, leadId });\n    }\n  } catch (e) {\n    // Fehler loggen aber weitermachen\n  }\n}\n\nif (allOpps.length === 0) {\n  return [];\n}\n\nreturn allOpps.map(o => ({ json: o }));"
      },
