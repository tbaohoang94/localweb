      "parameters": {
        "jsCode": "// DocuSeal Webhook Payload routen\nconst body = $json.body || $json;\nconst eventType = body.event_type || '';\nconst data = body.data || {};\n\n// Submitter-Email (wer das Event ausgeloest hat)\nconst submitterEmail = (data.email || '').toLowerCase().trim();\n\n// --- EMAIL WHITELIST ---\n// Nur Events von diesen Emails durchlassen\nconst allowedEmails = [\n  'bao.hoang@localweb.de',\n  'tbaohoang94@gmail.com'\n];\n\nif (!allowedEmails.includes(submitterEmail)) {\n  // Email nicht in Whitelist — Workflow stoppen\n  return [];\n}\n// --- ENDE WHITELIST ---\n\n// Template-ID aus verschiedenen moeglichen Positionen lesen\nconst templateId = data.submission?.template?.id\n  || data.template?.id\n  || 0;\n\nconst submitterRole = data.role || '';\n\n// DocuSeal Webhook feuert PRO Submitter, nicht pro Submission.\n// data.email IST der aktuelle Submitter.\n// Fuer Create Submission: die Email des aktuellen Submitters verwenden.\nconst secondPartyEmail = submitterEmail;\n\n// Dokument-URLs sammeln\nconst documents = data.documents || [];\nconst documentUrls = documents.map(d => d.url).filter(Boolean);\nconst documentNames = documents.map(d => d.name || 'Dokument').filter(Boolean);\n\n// Routing-Logik\nlet route = '';\nif (eventType === 'form.completed') {\n  if (templateId === 431151) {\n    route = 'send_email';\n  } else {\n    route = 'create_submission';\n  }\n} else if (eventType === 'form.viewed') {\n  route = 'update_viewed';\n} else {\n  return [];\n}\n\nreturn [{ json: {\n  _route: route,\n  eventType,\n  templateId,\n  submitterEmail,\n  submitterRole,\n  secondPartyEmail,\n  documentUrls,\n  documentNames,\n  submissionId: data.submission_id || data.submission?.id || 0,\n  rawData: data\n}}];"
      },
