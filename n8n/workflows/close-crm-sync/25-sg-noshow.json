{
  "name": "25 - Close CRM Sync - SG NoShow",
  "nodes": [
    {
      "parameters": {
        "inputSource": "passthrough"
      },
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        300
      ],
      "id": "e5beb478-d675-47eb-8f23-ff27345cc073"
    },
    {
      "parameters": {
        "jsCode": "const input = $json;\nconst ergebnis = (input.customFields || {})['custom.cf_1jQaceRH6hI9L0W635q7xDopqEbAbPyIy2RkOLPfk8o'] || '';\n\n// Leeres Ergebnis → nichts tun\nif (!ergebnis) {\n  return [];\n}\n\n// '2 - Absage mit neuem Termin' → Opp Status auf SG Anstehend zuruecksetzen\n// Alle anderen Ergebnisse werden in Prepare Opp Update behandelt\nreturn [{ json: { ...input, ergebnis } }];"
      },
      "name": "Resolve Ergebnis",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        300
      ],
      "id": "43652cf5-b5d8-47ac-bb6d-8972f077566f"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.close.com/api/v1/opportunity/?lead_id={{ $json.leadId }}&status_type=active&_limit=1&_order_by=-date_created",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Basic YXBpXzJKd0JqaHMwYmZCUmJ5d3dHeXA0blUuMWlWV0NZVUUyRzE3NWh6NjJmNEJMRzo="
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "fullResponse": false
            }
          }
        }
      },
      "name": "Get Active Opportunity",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        480,
        300
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "onError": "continueErrorOutput",
      "id": "f790448a-07a4-4693-ba24-7ea841968e2c"
    },
    {
      "parameters": {
        "jsCode": "const input = $('Resolve Ergebnis').first().json;\nconst oppResponse = $json;\nconst opportunities = oppResponse.data || [];\n\nif (opportunities.length === 0) {\n  return [];\n}\n\nconst oppId = opportunities[0].id;\nconst ergebnis = input.ergebnis;\n\nlet body = {};\n\nif (ergebnis === '1 - Absage ohne neuen Termin') {\n  // No Show: Status auf SG - No Show setzen + Custom Field markieren\n  body = {\n    status_id: 'stat_aDxAHmrsfcFVJXvRQai1Rbb4TdGWkwbXsZ1JxRr2NcE',\n    'custom.cf_30D240z87Zko9PKJucdQabdhPNryXzHdmiASz2ABOuo': 'No Show'\n  };\n} else if (ergebnis === '3 - Komplette Absage') {\n  // Komplett verloren\n  body = { status_id: 'stat_2NjdTtgLsl931S2nrmOLTK7IWW7KV0JVsiTwS7zexT4' };\n}\n\n// Kein bekanntes Ergebnis -> nichts tun\nif (Object.keys(body).length === 0) {\n  return [];\n}\n\nreturn [{ json: { ...input, oppId, updateBody: body } }];"
      },
      "name": "Prepare Opp Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        200
      ],
      "id": "d304740a-f2e7-4b04-bf56-c3e48108952b"
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "=https://api.close.com/api/v1/opportunity/{{ $json.oppId }}",
        "authentication": "none",
