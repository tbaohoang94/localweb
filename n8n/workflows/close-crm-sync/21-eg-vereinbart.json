    {
      "parameters": {
        "jsCode": "// Calls mit Recording vorbereiten fuer HTTP Download\nconst calls = $('Check Calls').first().json.calls || [];\n\n// Nur den ersten Call ausgeben (Loop spaeter moeglich)\nif (calls.length === 0) {\n  return [{ json: { transcripts: [], count: 0, errors: [] } }];\n}\n\nconst call = calls[0];\nreturn [{ json: {\n  callId: call.id,\n  recordingUrl: call.recording_url,\n  callsCount: calls.length\n}}];\n"
