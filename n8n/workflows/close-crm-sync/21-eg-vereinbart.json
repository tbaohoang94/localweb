    {
      "parameters": {
        "jsCode": "// Pruefen ob Activity schon mal published war\nconst trigger = $('Execute Workflow Trigger').first().json;\nconst lastPublished = trigger.rawEvent?.previous_data?.last_published_at;\n\nif (lastPublished) {\n  return []; // War schon published → Flow stoppt\n}\n\nreturn [{ json: trigger }]; // Erstes Publish → weiter"
      },
      "name": "Erstes Publish?",
