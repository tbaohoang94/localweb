    },
    {
      "parameters": {
        "jsCode": "// Calls mit Recording filtern, Versuch zaehlen, Abbruch bei >= 2\nconst callsData = $json.data || [];\n\n// attempt aus Prepare oder Next Attempt holen\nlet prevAttempt = 0;\ntry { prevAttempt = $('Next Attempt').first().json.attempt; } catch(e) {\n  try { prevAttempt = $('Prepare').first().json.attempt; } catch(e2) {}\n}\nconst attempt = prevAttempt + 1;\n\n// Nur nach recording_url filtern — NICHT nach user_id\n// Der Call gehoert zum richtigen Lead (GET Calls filtert bereits nach lead_id)\n// Der Call kann aber von einem anderen User gefuehrt worden sein\nconst callsWithRecording = callsData.filter(c => c.recording_url);\n\nif (callsWithRecording.length > 0) {\n  return [{ json: { _action: 'transcribe', calls: callsWithRecording, attempt } }];\n}\n\nif (attempt >= 2) {\n  return []; // Max Versuche erreicht → Flow stoppt\n}\n\nreturn [{ json: { _action: 'retry', calls: [], attempt } }];"
      },
      "name": "Check Calls",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
