# Google Maps Pipeline — Frontend Environment
# Kopiere nach .env.local: cp .env.example .env.local

# Supabase (anon key — sicher fuer Client-Side)
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...ANON_KEY

# Sentry (nur in Production aktiv)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=google-maps-pipeline
SENTRY_AUTH_TOKEN=sntrys_...
