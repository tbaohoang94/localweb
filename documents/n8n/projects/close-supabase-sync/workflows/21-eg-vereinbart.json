        "jsonBody": "={{ JSON.stringify({ entity: 'webhook_21_eg_vereinbart', status: 'error', error_message: ($json.error?.message || $json.errorMessage || 'Unknown error in 21-eg-vereinbart').substring(0, 500), started_at: new Date().toISOString(), finished_at: new Date().toISOString() }) }}",
        "options": {}
      },
      "id": "log-error-21",
      "name": "Log Error to Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 600],
      "continueOnFail": true
    }
  ],
