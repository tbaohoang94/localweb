      "parameters": {
        "jsCode": "// Parse chat input for test\nconst chatInput = $input.first()?.json?.chatInput || '';\nlet params = {};\n\ntry {\n  params = JSON.parse(chatInput);\n} catch (e) {\n  // Use defaults\n}\n\nreturn [{ json: params }];"
