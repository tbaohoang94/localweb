      "id": "parse-chat-activities",
      "name": "Parse Chat Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1040, 2192]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first()?.json || {};\n\nif (input.date_gt && input.date_lt) {\n  return [{\n    json: {\n      date_gt: input.date_gt,\n      date_lt: input.date_lt,\n      date_record_id: input.date_record_id || '',\n      test_mode: input.test_mode || false,\n      limit: input.limit || 0\n    }\n  }];\n}\n\nconst today = new Date();\ntoday.setHours(0, 0, 0, 0);\nconst tomorrow = new Date(today);\ntomorrow.setDate(tomorrow.getDate() + 1);\n\nreturn [{\n  json: {\n    date_gt: today.toISOString(),\n    date_lt: tomorrow.toISOString(),\n    date_record_id: '',\n    test_mode: true,\n    limit: 0\n  }\n}];"
      },
