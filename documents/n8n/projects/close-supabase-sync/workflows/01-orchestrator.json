      "position": [1040, 512],
      "credentials": { "supabaseApi": { "id": "SUPABASE_CREDENTIAL_ID", "name": "Supabase" } }
    },
    {
      "parameters": {
        "jsCode": "const initParams = $('Init Parameters').first().json;\n\nreturn $input.all().map(item => {\n  const dateStr = item.json.date;\n  const dateObj = new Date(dateStr + 'T00:00:00.000Z');\n  const nextDay = new Date(dateObj);\n  nextDay.setDate(nextDay.getDate() + 1);\n\n  return {\n    json: {\n      date_gt: dateObj.toISOString(),\n      date_lt: nextDay.toISOString(),\n      date_record_id: item.json.id || '',\n      test_mode: initParams.test_mode || false,\n      limit: initParams.limit || 0\n    }\n  };\n});"
      },
