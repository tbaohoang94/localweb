      "typeVersion": 1.1,
      "position": [0, 560],
      "webhookId": "orchestrator-test"
    },
    {
      "parameters": {
        "jsCode": "// Parse chat input for test parameters\nconst chatInput = $input.first()?.json?.chatInput || '';\nlet params = { test_mode: true, date: null, limit: 0 };\n\ntry {\n  const parsed = JSON.parse(chatInput);\n  params = { ...params, ...parsed };\n} catch (e) {\n  // If not JSON, try to parse as simple date\n  if (chatInput.match(/^\\d{4}-\\d{2}-\\d{2}$/)) {\n    params.date = chatInput;\n  }\n}\n\nreturn [{ json: params }];"
      },
      "id": "parse-chat-input",
      "name": "Parse Chat Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [224, 560]
    },
    {
      "parameters": {
        "workflowId": {
          "__rl": true,
          "value": "yg2xtQQAUaiLkLXi",
          "mode": "list",
          "cachedResultName": "02-add-new-user"
        },
        "options": {}
      },
      "id": "add-users",
      "name": "Add new Users",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.1,
      "position": [272, 0]
    },
    {
      "parameters": {
        "jsCode": "// Test-Modus Parameter\nconst input = $input.first()?.json || {};\n\nreturn [{\n  json: {\n    test_mode: input.test_mode === true || input.test_mode === 'true' || false,\n    date: input.date || null,\n    limit: input.limit ? parseInt(String(input.limit)) : 0\n  }\n}];"
      },
      "id": "init-params",
      "name": "Init Parameters",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [272, 304]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "version": 2,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-test-mode",
              "leftValue": "={{ $json.test_mode }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-test-mode",
      "name": "If Test Mode",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [528, 304]
    },
    {
      "parameters": {
        "jsCode": "const params = $('Init Parameters').first().json;\nconst date = params.date || new Date().toISOString().split('T')[0];\n\nreturn [{\n  json: {\n    id: 'test-record',\n    date: date,\n    status: 'test'\n  }\n}];"
      },
      "id": "build-test-date",
      "name": "Build Test Date",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [784, 112]
