      ]
    },
    {
      "parameters": {
        "fromEmail": "={{ $env.NOTIFICATION_EMAIL }}",
        "toEmail": "={{ $env.NOTIFICATION_EMAIL }}",
        "subject": "=Close.io Leads Export - {{ $json.date }} ({{ $json.count }} Leads)",
        "emailFormat": "text",
        "message": "={{ $json.count }} Leads bereit für Close.io Import.\n\nCSV im Anhang. Bitte in Close.io unter Leads > Import hochladen.",
        "options": {
          "attachments": "csv"
        }
      },
      "id": "send-email",
      "name": "Send Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [
        2016,
        400
      ],
      "webhookId": "1c328b1a-0565-4e9e-aa3e-922ab3a2b65b",
      "credentials": {
        "smtp": {
          "id": "jKqq3tIwM4LGdZgW",
          "name": "SMTP account"
        }
      },
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "jsCode": "const ids = $('Build CSV').first().json.ids;\nconst chunkSize = 500;\nconst chunks = [];\nfor (let i = 0; i < ids.length; i += chunkSize) {\n  chunks.push(ids.slice(i, i + chunkSize));\n}\nreturn chunks.map(chunk => ({\n  json: { idFilter: `in.(${chunk.join(',')})` }\n}));"
      },
      "id": "chunk-ids",
      "name": "Chunk IDs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        192
      ]
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "loop-chunks",
