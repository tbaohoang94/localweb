      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1792, 80],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "function cleanHtmlToText(html) {\n  if (!html || typeof html !== 'string') return '';\n  if (html.includes('Attention Required! | Cloudflare')) return '';\n\n  let cleaned = html.replace(/<(script|style|noscript|svg|canvas|iframe|video|audio|picture|source)[^>]*>([\\s\\S]*?)<\\/\\1>/gi, '');\n  cleaned = cleaned.replace(/<(script|style|noscript|svg|canvas|iframe|video|audio|picture|source)[^>]*\\/>/gi, '');\n\n  const parts = [];\n  const tagPattern = /<(p|li|h[1-6])[^>]*>([\\s\\S]*?)<\\/\\1>/gi;\n  let match;\n  \n  while ((match = tagPattern.exec(cleaned)) !== null) {\n    let text = match[2];\n    text = text.replace(/<br[^>]*>/gi, '\\n');\n    text = text.replace(/<[^>]+>/g, '');\n    text = text.replace(/\\u00a0/g, ' ');\n    text = text.replace(/[ \\t]+/g, ' ');\n    text = text.replace(/\\n{2,}/g, '\\n');\n    text = text.trim();\n    if (text) parts.push(text);\n  }\n  return parts.join('\\n');\n}\n\nconst previousNode = $('Create Impressum URL').first().json;\nconst homepageText = previousNode.homepageText || '';\n\nconst impressumHtml = $input.first().json.data || $input.first().json.body || '';\nconst impressumText = cleanHtmlToText(impressumHtml);\n\nlet combined = '';\nif (homepageText) combined += `[HOMEPAGE]\\n${homepageText}\\n\\n`;\nif (impressumText) combined += `[IMPRESSUM]\\n${impressumText}`;\n\nconst text = combined.slice(0, 12000);\nconst website = $('Loop Over Items').first().json.website || '';\n\nreturn [{\n  json: {\n    website: website,\n    text: text\n  }\n}];"
      },
