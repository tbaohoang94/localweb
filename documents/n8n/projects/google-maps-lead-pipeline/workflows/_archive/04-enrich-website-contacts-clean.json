        "jsCode": "const openaiResponse = $input.first().json;\n\nlet parsed = null;\ntry {\n  const content = openaiResponse.choices[0].message.content;\n  parsed = JSON.parse(content);\n} catch (e) {\n  return [{ json: { success: false, error: 'Parse error: ' + e.message } }];\n}\n\nreturn [{\n  json: {\n    success: true,\n    website_summary: parsed.website_summary || '',\n    im_contact_name: (parsed.geschaeftsfuehrer || []).join(', '),\n    im_email: parsed.email || null,\n    im_tel: parsed.phone || null\n  }\n}];"
