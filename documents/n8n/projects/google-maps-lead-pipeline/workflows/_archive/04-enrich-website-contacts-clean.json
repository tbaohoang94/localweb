    {
      "parameters": {
        "jsCode": "// Get the HTML response from HTTP Request node\nconst html = $input.first().json.data || '';\n\nfunction cleanHtmlToText(html) {\n  if (!html || typeof html !== 'string') return '';\n  if (html.includes('Attention Required! | Cloudflare')) return '';\n\n  let cleaned = html.replace(/<(script|style|noscript|svg|canvas|iframe|video|audio|picture|source)[^>]*>([\\s\\S]*?)<\\/\\1>/gi, '');\n  cleaned = cleaned.replace(/<(script|style|noscript|svg|canvas|iframe|video|audio|picture|source)[^>]*\\/>/gi, '');\n\n  const parts = [];\n  const tagPattern = /<(p|li|h[1-6])[^>]*>([\\s\\S]*?)<\\/\\1>/gi;\n  let match;\n  \n  while ((match = tagPattern.exec(cleaned)) !== null) {\n    let text = match[2];\n    text = text.replace(/<br[^>]*>/gi, '\\n');\n    text = text.replace(/<[^>]+>/g, '');\n    text = text.replace(/\\u00a0/g, ' ');\n    text = text.replace(/[ \\t]+/g, ' ');\n    text = text.replace(/\\n{2,}/g, '\\n');\n    text = text.trim();\n    if (text) parts.push(text);\n  }\n\n  return parts.join('\\n');\n}\n\nconst homepageText = cleanHtmlToText(html);\n\nreturn [{\n  json: {\n    homepageText: homepageText\n  }\n}];"
      },
      "id": "html-to-text",
      "name": "Clean Homepage HTML",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1344, 80]
    },
    {
      "parameters": {
        "jsCode": "const loopItem = $('Loop Over Items').first().json;\nconst website = loopItem.website || '';\nconst homepageText = $input.first().json.homepageText || '';\n\nlet baseUrl = website.trim();\nif (!baseUrl.startsWith('http')) {\n  baseUrl = 'https://' + baseUrl;\n}\nbaseUrl = baseUrl.replace(/\\/$/, '');\n\nconst impressumUrl = baseUrl + '/impressum';\n\nreturn [{\n  json: {\n    impressumUrl: impressumUrl,\n    homepageText: homepageText\n  }\n}];"
      },
