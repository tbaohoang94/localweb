      "parameters": {
        "url": "=https://api.apify.com/v2/acts/compass~crawler-google-places/runs?limit=20&desc=true&token={{ $env.APIFY_API_TOKEN }}",
        "options": {}
      },
      "id": "check-active-runs",
      "name": "Get Apify Runs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1568, -96],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "jsCode": "// Count how many Apify runs are still active (READY or RUNNING)\nconst response = $input.first().json;\nconst runs = response.data?.items || [];\nconst activeRuns = runs.filter(run =>\n  ['READY', 'RUNNING'].includes(run.status)\n);\n\nreturn [{\n  json: {\n    activeCount: activeRuns.length,\n    totalChecked: runs.length\n  }\n}];"
      },
      "id": "count-active-runs",
      "name": "Count Active Runs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1792, -96]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 3,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-active-count-zero",
              "leftValue": "={{ $json.activeCount }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-all-done",
      "name": "If All Done",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [2016, -24]
    },
    {
      "parameters": {
        "jsCode": "// Get Apify runs data and create individual items for status update\nconst apiResponse = $(\"Get Apify Runs\").first().json;\nconst runs = apiResponse.data?.items || [];\n\n// Map completed Apify runs to scrape_run status updates\nconst completedRuns = runs\n  .filter(run => !['READY', 'RUNNING'].includes(run.status))\n  .map(run => ({\n    json: {\n      apify_run_id: run.id,\n      status: run.status === 'SUCCEEDED' ? 'finished' : 'failed'\n    }\n  }));\n\n// If no completed runs found, return a passthrough item\nif (completedRuns.length === 0) {\n  return [{ json: { noUpdates: true } }];\n}\n\nreturn completedRuns;"
      },
      "id": "map-run-statuses",
      "name": "Map Run Statuses",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2240, -24]
    },
