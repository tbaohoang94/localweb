            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_GOOGLE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=representation" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"scrape_status\": {{ JSON.stringify($json.status) }},\n  \"scrape_finished_at\": {{ JSON.stringify($now.toISO()) }}\n}",
        "options": {}
      },
