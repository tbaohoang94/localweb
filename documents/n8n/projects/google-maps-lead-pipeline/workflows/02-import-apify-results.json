    {
      "parameters": {
        "jsCode": "function normalizeWebsite(url) {\n  if (!url) return null;\n  const cleaned = String(url).trim();\n  if (!cleaned) return null;\n  const match = cleaned.match(/^(https?:\\/\\/[^\\/?#]+)/);\n  if (match) return match[1];\n  const withProtocol = 'https://' + cleaned;\n  const match2 = withProtocol.match(/^(https?:\\/\\/[^\\/?#]+)/);\n  return match2 ? match2[1] : null;\n}\n\nconst items = $input.all();\nconst filtered = items.filter(item => item.json.placeId && !item.json.permanentlyClosed);\n\n// Deduplicate by placeId (keep last occurrence = highest rank)\nconst deduped = new Map();\nfor (const item of filtered) {\n  deduped.set(item.json.placeId, item);\n}\nconst unique = Array.from(deduped.values());\nconst totalCount = unique.length;\n\nreturn unique.map(item => {\n  const d = item.json;\n  return {\n    json: {\n      _totalCount: totalCount,\n      placeId: d.placeId,\n      title: d.title || null,\n      categoryName: d.categoryName || null,\n      address: d.address || null,\n      city: d.city || null,\n      postalCode: d.postalCode || null,\n      countryCode: d.countryCode || null,\n      phone: d.phone || null,\n      website: normalizeWebsite(d.website),\n      totalScore: d.totalScore || null,\n      reviewsCount: d.reviewsCount || null,\n      location: {\n        lat: d.location && d.location.lat ? d.location.lat : null,\n        lng: d.location && d.location.lng ? d.location.lng : null\n      },\n      permanentlyClosed: d.permanentlyClosed || false,\n      phoneUnformatted: d.phoneUnformatted || null,\n      fid: d.fid || null,\n      cid: d.cid || null,\n      searchString: d.searchString || null,\n      rank: d.rank || null\n    }\n  };\n});"
      },
      "id": "normalize-data",
      "name": "Normalize Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1568, -304]
    },
