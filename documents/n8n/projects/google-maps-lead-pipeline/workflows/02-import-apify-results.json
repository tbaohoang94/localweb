    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst batch = items.map(item => {\n  const d = item.json;\n  return {\n    place_id: d.placeId,\n    name: d.title,\n    category: d.categoryName,\n    address: d.address,\n    city: d.city,\n    postal_code: d.postalCode,\n    country: d.countryCode,\n    phone: d.phone,\n    website: d.website,\n    rating: d.totalScore || null,\n    reviews_count: d.reviewsCount || null,\n    latitude: d.location && d.location.lat ? d.location.lat : null,\n    longitude: d.location && d.location.lng ? d.location.lng : null,\n    permanently_closed: d.permanentlyClosed || false,\n    phone_unformatted: d.phoneUnformatted || null,\n    fid: d.fid || null,\n    cid: d.cid || null,\n    search_string: d.searchString || null,\n    rank: d.rank || null\n  };\n});\n\nreturn [{ json: { batch } }];"
      },
