            { "name": "apikey", "value": "={{ $env.SUPABASE_GOOGLE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_GOOGLE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=representation" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"apify_run_id\": {{ JSON.stringify($json.runId) }},\n  \"scrape_status\": \"running\",\n  \"scraped_at\": {{ JSON.stringify($now.toISO()) }}\n}",
        "options": {}
      }
    }
