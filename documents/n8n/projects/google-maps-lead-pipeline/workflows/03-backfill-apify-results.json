{
  "id": "UnsVgD4lAxaiDzCY",
  "name": "03-backfill-apify-results",
  "active": false,
  "nodes": [
    {
      "parameters": {},
      "id": "trigger",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [0, 80]
    },
    {
      "parameters": {
        "url": "https://api.apify.com/v2/acts/compass~crawler-google-places/runs?limit=1000&desc=true",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "options": {}
      },
      "id": "get-all-runs",
      "name": "Get All Apify Runs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [224, 80],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "credentials": {
        "httpBearerAuth": { "id": "H7EaKB5yYzqhBgZ8", "name": "Apify" }
      }
    },
    {
      "parameters": {
        "jsCode": "const apifyResponse = $(\"Get All Apify Runs\").first().json;\nconst runs = apifyResponse.data?.items || [];\nconst succeeded = runs.filter(run => run.status === 'SUCCEEDED');\n\n// HTTP node returns each array element as separate item\nconst existingRunItems = $(\"HTTP Get Scraped Locations\").all();\nconst processedIds = new Set(existingRunItems.map(item => item.json.apify_run_id));\n\nconst newRuns = succeeded.filter(run => !processedIds.has(run.id));\n\nif (newRuns.length === 0) {\n  throw new Error(\n    `No new runs to process. ${succeeded.length} succeeded, ${processedIds.size} already in locations.`\n  );\n}\n\nreturn newRuns.map(run => ({\n  json: {\n    runId: run.id,\n    datasetId: run.defaultDatasetId,\n    startedAt: run.startedAt,\n    finishedAt: run.finishedAt\n  }\n}));"
      },
      "id": "filter-succeeded",
      "name": "Filter New Runs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [672, 80]
    },
    {
      "parameters": { "options": {} },
      "id": "loop-runs",
      "name": "Loop Over Runs",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1104, 80]
    },
    {
      "parameters": {
        "url": "=https://api.apify.com/v2/actor-runs/{{ $json.runId }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "options": {}
      },
      "id": "get-run-details",
      "name": "Get Run Details",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1328, 0],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000,
      "credentials": {
        "httpBearerAuth": { "id": "H7EaKB5yYzqhBgZ8", "name": "Apify" }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.apify.com/v2/datasets/{{ $('Loop Over Runs').first().json.datasetId }}/items?limit=1",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "options": {}
      },
      "id": "get-first-dataset-item",
      "name": "Get First Dataset Item",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1440, 0],
      "credentials": {
        "httpBearerAuth": { "id": "H7EaKB5yYzqhBgZ8", "name": "Apify" }
      }
    },
    {
      "parameters": {
        "jsCode": "const loopItem = $('Loop Over Runs').first().json;\nconst runId = loopItem.runId;\nconst datasetId = loopItem.datasetId;\n\n// Get searchString from dataset item (first item)\nconst datasetItem = $input.first().json;\nconst searchString = datasetItem.searchString || '';\n\n// Parse searchString: \"Suchbegriff Stadt Land\"\nconst parts = searchString.trim().split(/\\s+/);\n\nlet query = '';\nlet city = '';\nlet country = '';\n\nif (parts.length >= 3) {\n  country = parts[parts.length - 1];\n  city = parts[parts.length - 2];\n  query = parts.slice(0, -2).join(' ');\n} else if (parts.length === 2) {\n  query = parts[0];\n  city = parts[1];\n  country = 'Unknown';\n} else if (parts.length === 1) {\n  query = parts[0];\n  city = 'Unknown';\n  country = 'Unknown';\n}\n\nreturn [{\n  json: {\n    runId,\n    datasetId,\n    searchString,\n    query: query || 'Unknown',\n    city: city || 'Unknown',\n    country: country || 'Unknown'\n  }\n}];"
      },
      "id": "parse-search-string",
      "name": "Parse Search String",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1664, 0]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.id }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "exists" },
              "id": "location-exists"
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "location-exists-check",
      "name": "Location Exists?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [2000, 0]
    },
    {
      "parameters": {
        "jsCode": "// HTTP Find Location returns array as items - first item is the found location\nconst locationData = $input.first().json;\nconst parseData = $('Parse Search String').first().json;\n\nreturn [{\n  json: {\n    locationId: locationData.id,\n    runId: parseData.runId,\n    datasetId: parseData.datasetId,\n    query: parseData.query,\n    city: parseData.city,\n    country: parseData.country\n  }\n}];"
      },
      "id": "use-existing-location",
      "name": "Use Existing Location",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2224, -80]
    },
    {
      "parameters": {
        "jsCode": "// HTTP Create Location returns array as items - first item is the created location\nconst newLocation = $input.first().json;\nconst parseData = $('Parse Search String').first().json;\n\nreturn [{\n  json: {\n    locationId: newLocation.id,\n    runId: parseData.runId,\n    datasetId: parseData.datasetId,\n    query: parseData.query,\n    city: parseData.city,\n    country: parseData.country\n  }\n}];"
      },
      "id": "use-new-location",
      "name": "Use New Location",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2448, 80]
    },
    {
      "parameters": {
        "workflowId": { "__rl": true, "mode": "id", "value": "59tTad4B9Ryv2O67" },
        "workflowInputs": {
          "mappingMode": "defineBelow",
          "value": {},
          "matchingColumns": [],
          "schema": [],
          "attemptToConvertTypes": false,
          "convertFieldsToString": true
        },
        "options": { "waitForSubWorkflow": true }
      },
      "id": "execute-import",
      "name": "Execute Import Workflow",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [2896, 0],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "await new Promise(resolve => setTimeout(resolve, 1000));\nreturn $input.all();"
      },
      "id": "wait-1s",
