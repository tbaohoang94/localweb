# n8n Docker Environment
# Copy this file to .env and fill in real values

# Public URL
N8N_EDITOR_BASE_URL=https://n8n.localweb.de
WEBHOOK_URL=https://n8n.localweb.de/

# n8n Encryption (generate a long random string)
N8N_ENCRYPTION_KEY=change_me_to_a_long_random_string
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true

# PostgreSQL
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me

# Same values for n8n DB connection
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=change_me
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432

# Production only
N8N_HOST=n8n.localweb.de
N8N_LOG_FORMAT=json
N8N_LOG_LEVEL=warn
N8N_METRICS=true
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379

# Supabase google-maps-lead-pipeline
SUPABASE_GOOGLE_URL=https://your-project.supabase.co
SUPABASE_GOOGLE_KEY=your_supabase_service_role_key_here

# Supabase close-airtable-sync
SUPABASE_LEADS_URL=
SUPABASE_LEADS_KEY=

# Airtable
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_airtable_base_id_here

# Apify
APIFY_API_TOKEN=your_apify_token_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here