\\u00a0/g, ' ');\n\n  return raw\n    .replace(/[ \\t]+/g, ' ')\n    .replace(/\\n{2,}/g, '\\n')\n    .trim();\n}\n\n// --- Hole alle Items vom Merge Node ---\nconst inputs = $input.all();\n\n// --- Jeden HTML-Block säubern ---\nconst texts = inputs.map(item => cleanHtmlToText(item.json.data || ''));\n\n// --- Zu einem Gesamttext kombinieren ---\nconst combined = texts.filter(Boolean).join('\\n');\n\n// --- Ergebnis zurückgeben ---\nreturn [\n  {\n    json: {\n      text: combined\n    }\n  }\n];\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[1056,128],"id":"c11833ae-a4c8-4503-b4c4-70d0b42ac705","name":"Code"},{"parameters":{},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[832,128],"id":"68519c51-b1a1-40f8-bbbb-2e4996a59c3c","name":"Merge"},{"parameters":{"jsCode":"// Nimm alle Items vom vorherigen Node\nconst items = $input.all();\n\n// Zieh \"output\" nach oben, sodass Keys direkt auf Root-Ebene stehen\nconst flattened = items.map(item => {\n  return { json: item.json.output };\n});\n\n// Array zurückgeben\nreturn flattened;\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[528,416],"id":"3a6a7225-4546-4be7-9723-f7faf83cdc08","name":"Code2"},{"parameters":{"operation":"append","documentId":{"__rl":true,"value":"19dwQwHHVKgicOwy9PLORmm6R04-8xwIU_UuyxTWcCeQ","mode":"list","cachedResultName":"Maps Data","cachedResultUrl":"https://docs.google.com/spreadsheets/d/19dwQwHHVKgicOwy9PLORmm6R04-8xwIU_UuyxTWcCeQ/edit?usp=drivesdk"},"sheetName":{"__rl":true,"value":1060328058,"mode":"list","cachedResultName":"Enrichted Data","cachedResultUrl":"https://docs.google.com/spreadsheets/d/19dwQwHHVKgicOwy9PLORmm6R04-8xwIU_UuyxTWcCeQ/edit#gid=1060328058"},"columns":{"mappingMode":"autoMapInputData","value":{},"matchingColumns":[],"schema":[{"id":"url","displayName":"url","required":false,"defaultMatch":false,"display":true,"type":"string","canBeUsedToMatch":true},{"id":"title","displayName":"title","required":false,"defaultMatch":false,"display":